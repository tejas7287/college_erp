<odoo>

    <record id="course_form" model="ir.ui.view">
        <field name="name">course.form</field>
        <field name="model">college.course</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="duration"/>
                    </group>

                    <notebook>
                        <page string="Students">
                            <field name="student_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="course_tree" model="ir.ui.view">
        <field name="name">course.tree</field>
        <field name="model">college.course</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="duration"/>
            </list>
        </field>
    </record>

    <record id="action_courses" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">college.course</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>